# ─── Gemini API ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASS=

# ─── MongoDB Connection ─────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/aimock

# ─── JWT Secret ──────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_strong_random_string

# ─── Code Execution ──────────────────────────────────────────────────────────
# Uses Piston API — no key needed, no configuration required.
